-- Create continuous aggregates for analytics
CREATE MATERIALIZED VIEW hourly_bot_metrics
WITH (timescaledb.continuous) AS
SELECT 
    time_bucket('1 hour', timestamp) AS bucket,
    tenant_id,
    bot_id,
    COUNT(*) AS total_events,
    COUNT(*) FILTER (WHERE event_type = 'error') AS error_count,
    AVG(duration_ms) AS avg_duration_ms,
    AVG(confidence) FILTER (WHERE confidence IS NOT NULL) AS avg_confidence
FROM execution_events
WHERE bot_id IS NOT NULL
GROUP BY bucket, tenant_id, bot_id;

-- Create function for chain hashing in audit ledger
CREATE OR REPLACE FUNCTION generate_chain_hash()
RETURNS TRIGGER AS $$
BEGIN
    -- Get the previous chain hash
    SELECT chain_hash INTO NEW.previous_chain_hash
    FROM audit_ledger
    WHERE tenant_id = NEW.tenant_id
    ORDER BY timestamp DESC
    LIMIT 1;
    
    -- Generate new chain hash
    NEW.chain_hash = encode(
        digest(
            COALESCE(NEW.previous_chain_hash, '') || 
            NEW.id::text || 
            NEW.timestamp::text || 
            NEW.event_type || 
            NEW.resource_type || 
            NEW.resource_id::text || 
            NEW.action || 
            COALESCE(NEW.changes::text, ''),
            'sha256'
        ),
        'hex'
    );
    
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- Create trigger for chain hashing
CREATE TRIGGER audit_ledger_chain_hash
    BEFORE INSERT ON audit_ledger
    FOR EACH ROW
    EXECUTE FUNCTION generate_chain_hash();

-- Create function to update updated_at timestamp
CREATE OR REPLACE FUNCTION update_updated_at_column()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = NOW();
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- Apply updated_at trigger to relevant tables
CREATE TRIGGER update_tenants_updated_at BEFORE UPDATE ON tenants
    FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();

CREATE TRIGGER update_users_updated_at BEFORE UPDATE ON users
    FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();

CREATE TRIGGER update_workflow_definitions_updated_at BEFORE UPDATE ON workflow_definitions
    FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();

CREATE TRIGGER update_bot_agents_updated_at BEFORE UPDATE ON bot_agents
    FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();